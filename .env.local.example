# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# 랜딩 히어로 MP4 — 저장소에 public/main.mp4 없거나 Vercel 미리보기에서 404일 때
# 절대 URL( Vercel Blob, Supabase Storage, CDN 등 ). 우선 재생되고 실패 시 /main.mp4 시도
# NEXT_PUBLIC_LANDING_VIDEO_URL=https://example.com/main.mp4
# 비디오 로딩 전·실패 후 표시( public/hero-poster.jpg 처럼 경로 또는 URL )
# NEXT_PUBLIC_LANDING_VIDEO_POSTER_URL=/hero-poster.jpg
# NEXT_PUBLIC_LANDING_HERO_FALLBACK_IMG=/hero-fallback.jpg
